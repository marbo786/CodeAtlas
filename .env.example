# ==============================================================================
# CodeAtlas Environment Configuration
# Copy this file to .env and adjust values for your environment.
# ==============================================================================

# ── Backend Configuration (parser-service) ──
# API Key used by the frontend to authenticate with the parser API
PARSER_API_KEY=dev_api_key_123

# The absolute path on the host or inside the container where repos are stored.
# The parser will reject requests outside of this root (Path Sandboxing).
PARSER_ALLOWED_REPO_ROOT=/projects

# Allowed origins for CORS (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,*


# ── Frontend Configuration (Vite) ──
# The base URL of the parser API
VITE_API_BASE_URL=http://localhost:8000

# Must match PARSER_API_KEY
VITE_API_KEY=dev_api_key_123

# URL for the n8n webhook (Chat agent)
# Leave blank to run frontend in "Not Configured" demo mode
VITE_N8N_WEBHOOK_URL=


# ── Database Configuration (PostgreSQL) ──
POSTGRES_USER=codeatlas_admin
POSTGRES_PASSWORD=super_secret_dev_password
POSTGRES_DB=codeatlas_db

# ── n8n Configuration ──
N8N_PORT=5678
